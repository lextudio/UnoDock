    <!-- ── Manager outer-edge buttons ──────────────────────────────────────── -->

    <DataTemplate x:Key="UnoDock_VS2010_DockAnchorableLeftTemplate">
        <Viewbox Stretch="Uniform">
            <Grid Background="{ThemeResource UnoDock_VS2010_DockingButtonStarBackgroundBrush}">
                <Border Padding="10"
                        Background="{ThemeResource UnoDock_VS2010_DockingButtonStarBackgroundBrush}"
                        CornerRadius="5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4*" />
                            <ColumnDefinition Width="4*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="50" Height="80" Margin="5"
                                BorderBrush="{ThemeResource UnoDock_VS2010_DockingButtonForegroundBrush}"
                                BorderThickness="20,5,5,5" />
                        <Border Grid.Column="1" Width="30" Height="80" Margin="5"
                                BorderBrush="Transparent" BorderThickness="0" />
                        <Path   Grid.Column="1" Width="25" Height="12.5"
                                Data="F1M1,15L8,1 15,15z"
                                Fill="{ThemeResource UnoDock_VS2010_DockingButtonForegroundArrowBrush}"
                                RenderTransformOrigin="0.5,0.5" Stretch="Fill">
                            <Path.RenderTransform><RotateTransform Angle="270" /></Path.RenderTransform>
                        </Path>
                    </Grid>
                </Border>
            </Grid>
        </Viewbox>
    </DataTemplate>

