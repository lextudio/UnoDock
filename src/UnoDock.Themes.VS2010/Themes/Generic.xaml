<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:AvalonDock.Controls"
    xmlns:dock="using:AvalonDock">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ms-appx:///UnoDock.Themes.VS2010/OverlayButtons.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--
        VS2010 control styles for UnoDock.
        Color values are resolved via StaticResource from Brushes.xaml merged
        in Theme.xaml before this dictionary.
        Resource key names are defined in Themes/ResourceKeys.cs.
    -->

    <Style x:Key="UnoDockThemeVs2010GridSplitterVerticalStyle" TargetType="controls:LayoutGridResizerControl">
        <Setter Property="Background" Value="{StaticResource UnoDock_VS2010_ResizerBackground}" />
    </Style>

    <Style x:Key="UnoDockThemeVs2010GridSplitterHorizontalStyle" TargetType="controls:LayoutGridResizerControl">
        <Setter Property="Background" Value="{StaticResource UnoDock_VS2010_ResizerBackground}" />
    </Style>

    <!-- ── DockingManager ───────────────────────────────────────────────── -->
    <Style TargetType="dock:DockingManager">
        <Setter Property="Background" Value="{StaticResource UnoDock_VS2010_Background}" />
        <Setter Property="GridSplitterVerticalStyle" Value="{StaticResource UnoDockThemeVs2010GridSplitterVerticalStyle}" />
        <Setter Property="GridSplitterHorizontalStyle" Value="{StaticResource UnoDockThemeVs2010GridSplitterHorizontalStyle}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="dock:DockingManager">
                    <Grid x:Name="PART_TemplateRoot" Background="{TemplateBinding Background}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*"    />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*"    />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ContentPresenter x:Name="PART_TopSidePanel"
                                          Grid.Row="0" Grid.Column="1"
                                          Content="{TemplateBinding TopSidePanel}" />
                        <ContentPresenter x:Name="PART_LeftSidePanel"
                                          Grid.Row="1" Grid.Column="0"
                                          Content="{TemplateBinding LeftSidePanel}" />
                        <ContentPresenter x:Name="PART_RightSidePanel"
                                          Grid.Row="1" Grid.Column="2"
                                          Content="{TemplateBinding RightSidePanel}" />
                        <ContentPresenter x:Name="PART_BottomSidePanel"
                                          Grid.Row="2" Grid.Column="1"
                                          Content="{TemplateBinding BottomSidePanel}" />

                        <ContentPresenter x:Name="PART_LayoutRootPanel"
                                          Grid.Row="1" Grid.Column="1"
                                          Content="{TemplateBinding LayoutRootPanel}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── LayoutAnchorSideControl ──────────────────────────────────────── -->
    <Style TargetType="controls:LayoutAnchorSideControl">
        <Setter Property="Background" Value="{StaticResource UnoDock_VS2010_AutoHideTabDefaultBackground}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:LayoutAnchorSideControl">
                    <Border Background="{TemplateBinding Background}">
                        <StackPanel x:Name="PART_TabPanel"
                                    Orientation="Vertical" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── LayoutDocumentPaneControl ────────────────────────────────────── -->
    <Style TargetType="controls:LayoutDocumentPaneControl">
        <Setter Property="Background" Value="{StaticResource UnoDock_VS2010_ContentBackground}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:LayoutDocumentPaneControl">
                    <Grid Background="{TemplateBinding Background}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Tab strip -->
                        <Grid x:Name="PART_TabStripHost"
                              Grid.Row="0"
                              Background="{StaticResource UnoDock_VS2010_TabBarBackground}">
                            <!-- 2px golden accent line at bottom of tab strip (VS2010 golden selected color) -->
                            <Border x:Name="BD"
                                    BorderBrush="{StaticResource UnoDock_VS2010_DocumentWellTabSelectedActiveBackground}"
                                    BorderThickness="0,0,0,2" />
                            <ItemsControl x:Name="PART_TabStrip"
                                          ItemsSource="{TemplateBinding ItemsSource}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="TabOuter"
                                                Background="Transparent"
                                                Margin="0,0,0,2"
                                                Tag="{Binding}"
                                                AutomationProperties.AutomationId="{Binding ContentId}">
                                            <StackPanel Orientation="Horizontal"
                                                        Padding="10,1,4,1"
                                                        MinWidth="80"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource UnoDock_VS2010_TabText}"
                                                           FontSize="12" />
                                                <Button x:Name="CloseBtn"
                                                        Width="16" Height="16"
                                                        Margin="6,0,0,0"
                                                        Padding="0"
                                                        CornerRadius="2"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Opacity="0"
                                                        IsHitTestVisible="False"
                                                        VerticalAlignment="Center"
                                                        Tag="{Binding}"
                                                        ToolTipService.ToolTip="Close">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    CornerRadius="{TemplateBinding CornerRadius}">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center" />
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                    <TextBlock Text="✕"
                                                               FontSize="9"
                                                               Foreground="{StaticResource UnoDock_VS2010_CloseButtonForeground}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <!-- Content area -->
                        <Border Grid.Row="1"
                                Background="{StaticResource UnoDock_VS2010_ContentBackground}"
                                BorderBrush="{StaticResource UnoDock_VS2010_PanelBorderBrush}"
                                BorderThickness="1,0,1,1">
                            <ContentPresenter Content="{TemplateBinding SelectedContent}" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── LayoutAnchorablePaneControl ──────────────────────────────────── -->
    <Style TargetType="controls:LayoutAnchorablePaneControl">
        <Setter Property="Background" Value="{StaticResource UnoDock_VS2010_ContentBackground}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:LayoutAnchorablePaneControl">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource UnoDock_VS2010_PanelBorderBrush}"
                            BorderThickness="1">
                    <Grid Background="{TemplateBinding Background}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Tool pane caption -->
                        <Border x:Name="PART_HeaderBorder"
                                Grid.Row="0"
                                Background="{StaticResource UnoDock_VS2010_ToolWindowCaptionInactiveBackground}"
                                BorderBrush="{StaticResource UnoDock_VS2010_PanelBorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="6,3,2,3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock x:Name="PART_HeaderTitle"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource UnoDock_VS2010_ToolWindowCaptionInactiveText}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Text="{Binding SelectedItem.Title, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=Tool Window}" />

                                <!-- Grip dots. Initial placeholder Data; LayoutAnchorablePaneControl
                                     regenerates it to span the actual header width. -->
                                <Path x:Name="PART_HeaderGrip"
                                      Grid.Column="1"
                                      Height="5"
                                      Margin="4,0,2,0"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Center"
                                      Fill="{StaticResource UnoDock_VS2010_ToolWindowCaptionInactiveGrip}"
                                      Data="M0,0 h1 v1 h-1z M4,0 h1 v1 h-1z M8,0 h1 v1 h-1z M12,0 h1 v1 h-1z M16,0 h1 v1 h-1z M20,0 h1 v1 h-1z M24,0 h1 v1 h-1z M28,0 h1 v1 h-1z M32,0 h1 v1 h-1z M36,0 h1 v1 h-1z M2,2 h1 v1 h-1z M6,2 h1 v1 h-1z M10,2 h1 v1 h-1z M14,2 h1 v1 h-1z M18,2 h1 v1 h-1z M22,2 h1 v1 h-1z M26,2 h1 v1 h-1z M30,2 h1 v1 h-1z M34,2 h1 v1 h-1z M38,2 h1 v1 h-1z" />

                                <Button x:Name="PART_HeaderMenu"
                                        Grid.Column="2"
                                        Width="18" Height="18"
                                        Margin="2,0,0,0"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="1"
                                        VerticalAlignment="Center"
                                        ToolTipService.ToolTip="Window menu">
                                    <Path Width="8" Height="8" Margin="0,0,0,1"
                                          Data="M 352.041,32.0005L 320,0.000162761L 384,0.000162761L 352.041,32.0005 Z"
                                          Fill="{StaticResource UnoDock_VS2010_ToolWindowCaptionButtonInactiveGlyph}"
                                          Stretch="Uniform" />
                                </Button>

                                <Button x:Name="PART_HeaderAutoHide"
                                        Grid.Column="3"
                                        Width="18" Height="18"
                                        Margin="2,0,0,0"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="1"
                                        VerticalAlignment="Center"
                                        ToolTipService.ToolTip="Auto Hide">
                                    <Path Width="11" Height="11"
                                          Data="M 128,17.475L 130.842,17.475L 130.842,2.91001L 130.842,0.608195L 130.842,0.000223796L 139.593,0.000223796L 145.003,0.000223796L 145.424,0.000223796L 145.424,17.475L 148.413,17.475L 148.413,20.3848L 139.684,20.3848L 139.684,32.0003L 136.752,32.0003L 136.752,20.3848L 128,20.3848L 128,17.475 Z M 133.774,2.91007L 133.774,17.475L 139.593,17.475L 139.593,2.91007L 133.774,2.91007 Z"
                                          Fill="{StaticResource UnoDock_VS2010_ToolWindowCaptionButtonInactiveGlyph}"
                                          Stretch="Uniform" />
                                </Button>

                                <Button x:Name="PART_HeaderClose"
                                        Grid.Column="4"
                                        Width="18" Height="18"
                                        Margin="2,0,0,0"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="1"
                                        VerticalAlignment="Center"
                                        ToolTipService.ToolTip="Close">
                                    <Path Width="10" Height="10" Margin="1,0,0,1"
                                          Data="M 0,2.0345e-005L 7.62109,2.0345e-005L 19.2627,12.0551L 30.9043,2.0345e-005L 38.5241,2.0345e-005L 23.0726,16.0003L 38.5234,32L 30.9023,32L 19.2621,19.9462L 7.62177,32L 0.00195313,32L 15.4521,16.001L 0,2.0345e-005 Z"
                                          Fill="{StaticResource UnoDock_VS2010_ToolWindowCaptionButtonInactiveGlyph}"
                                          Stretch="Uniform" />
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Tool window tab strip -->
                        <Border x:Name="PART_TabStripHost"
                                Grid.Row="2"
                                Background="{StaticResource UnoDock_VS2010_TabBarBackground}"
                                BorderBrush="{StaticResource UnoDock_VS2010_TabBarBorderBrush}"
                                BorderThickness="0,1,0,0">
                            <ItemsControl x:Name="PART_TabStrip"
                                          ItemsSource="{TemplateBinding ItemsSource}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Border x:Name="SelectedBD"
                                                    Margin="1,-1,1,0"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="0,1,0,0"
                                                    Visibility="Collapsed" />
                                            <Border x:Name="TabOuter"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="1,0,1,1"
                                                    Tag="{Binding}"
                                                    AutomationProperties.AutomationId="{Binding ContentId}">
                                                <TextBlock Text="{Binding Title}"
                                                           Padding="6,1,6,3"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource UnoDock_VS2010_ToolWindowTabUnselectedText}"
                                                           FontSize="11" />
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <Border Grid.Row="1"
                                Background="{StaticResource UnoDock_VS2010_ContentBackground}"
                                Padding="4">
                            <ContentPresenter Content="{TemplateBinding SelectedContent}" />
                        </Border>
                    </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── LayoutGridResizerControl ─────────────────────────────────────── -->
    <Style TargetType="controls:LayoutGridResizerControl">
        <Setter Property="Background" Value="{StaticResource UnoDock_VS2010_ResizerBackground}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:LayoutGridResizerControl">
                    <Grid Background="{TemplateBinding Background}">
                        <Thumb x:Name="PART_Thumb"
                               Background="Transparent"
                               Opacity="0" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
