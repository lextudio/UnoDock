<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:AvalonDock.Controls"
    xmlns:dock="using:AvalonDock">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ms-appx:///UnoDock.Themes.VS2013/OverlayButtons.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--
        VS2013 control styles for UnoDock.
        Color values are resolved via DynamicResource from the variant brush file
        (DarkBrushs.xaml / LightBrushs.xaml / BlueBrushs.xaml) that was merged
        in the outer XxxTheme.xaml before this dictionary.
        Resource key names are defined in Themes/ResourceKeys.cs.
    -->

    <Style x:Key="UnoDockThemeVs2013GridSplitterVerticalStyle" TargetType="controls:LayoutGridResizerControl">
        <Setter Property="Background" Value="{StaticResource UnoDock_VS2013_ResizerBackground}" />
    </Style>

    <Style x:Key="UnoDockThemeVs2013GridSplitterHorizontalStyle" TargetType="controls:LayoutGridResizerControl">
        <Setter Property="Background" Value="{StaticResource UnoDock_VS2013_ResizerBackground}" />
    </Style>

    <!-- ── DockingManager ───────────────────────────────────────────────── -->
    <Style TargetType="dock:DockingManager">
        <Setter Property="Background" Value="{StaticResource UnoDock_VS2013_Background}" />
        <Setter Property="GridSplitterVerticalStyle" Value="{StaticResource UnoDockThemeVs2013GridSplitterVerticalStyle}" />
        <Setter Property="GridSplitterHorizontalStyle" Value="{StaticResource UnoDockThemeVs2013GridSplitterHorizontalStyle}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="dock:DockingManager">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid x:Name="PART_TemplateRoot" Background="{TemplateBinding Background}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*"    />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*"    />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ContentPresenter x:Name="PART_TopSidePanel"
                                              Grid.Row="0" Grid.Column="1"
                                              Content="{TemplateBinding TopSidePanel}" />
                            <ContentPresenter x:Name="PART_LeftSidePanel"
                                              Grid.Row="1" Grid.Column="0"
                                              Content="{TemplateBinding LeftSidePanel}" />
                            <ContentPresenter x:Name="PART_RightSidePanel"
                                              Grid.Row="1" Grid.Column="2"
                                              Content="{TemplateBinding RightSidePanel}" />
                            <ContentPresenter x:Name="PART_BottomSidePanel"
                                              Grid.Row="2" Grid.Column="1"
                                              Content="{TemplateBinding BottomSidePanel}" />

                            <ContentPresenter x:Name="PART_LayoutRootPanel"
                                              Grid.Row="1" Grid.Column="1"
                                              Content="{TemplateBinding LayoutRootPanel}" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── LayoutAnchorSideControl ──────────────────────────────────────── -->
    <Style TargetType="controls:LayoutAnchorSideControl">
        <Setter Property="Background" Value="{StaticResource UnoDock_VS2013_TabBarBackground}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:LayoutAnchorSideControl">
                    <Border Background="{TemplateBinding Background}">
                        <StackPanel x:Name="PART_TabPanel"
                                    MinWidth="6"
                                    MinHeight="6"
                                    Orientation="Vertical" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── MenuFlyout / MenuFlyoutItem / MenuFlyoutSeparator ────────────── -->

    <!-- Popup container: flat VS2013 background, no acrylic. -->
    <Style TargetType="MenuFlyoutPresenter">
        <Setter Property="Background"       Value="{StaticResource UnoDock_VS2013_MenuBackground}" />
        <Setter Property="BorderBrush"      Value="{StaticResource UnoDock_VS2013_MenuBorder}" />
        <Setter Property="BorderThickness"  Value="1" />
        <Setter Property="Padding"          Value="0,2,0,2" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuFlyoutPresenter">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ScrollViewer HorizontalScrollMode="Disabled"
                                      VerticalScrollMode="Auto"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsPresenter />
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Each menu item: flat text, blue/yellow highlight on hover. -->
    <Style TargetType="MenuFlyoutItem">
        <Setter Property="Background"   Value="Transparent" />
        <Setter Property="Foreground"   Value="{StaticResource UnoDock_VS2013_MenuText}" />
        <Setter Property="Padding"      Value="22,4,22,4" />
        <Setter Property="FontSize"     Value="12" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuFlyoutItem">
                    <Border x:Name="LayoutRoot"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="LayoutRoot.Background"
                                                Value="{StaticResource UnoDock_VS2013_MenuItemHoveredBackground}" />
                                        <Setter Target="Label.Foreground"
                                                Value="{StaticResource UnoDock_VS2013_MenuItemHoveredText}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="LayoutRoot.Background"
                                                Value="{StaticResource UnoDock_VS2013_MenuItemHoveredBackground}" />
                                        <Setter Target="Label.Foreground"
                                                Value="{StaticResource UnoDock_VS2013_MenuItemHoveredText}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="Label.Foreground"
                                                Value="{StaticResource UnoDock_VS2013_MenuTextInactive}" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <TextBlock x:Name="Label"
                                   Text="{TemplateBinding Text}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="{TemplateBinding FontSize}"
                                   VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Separator: 1px horizontal rule. -->
    <Style TargetType="MenuFlyoutSeparator">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuFlyoutSeparator">
                    <Border Height="1"
                            Margin="0,2"
                            Background="{StaticResource UnoDock_VS2013_MenuSeparator}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── LayoutDocumentPaneControl ────────────────────────────────────── -->
    <Style TargetType="controls:LayoutDocumentPaneControl">
        <Setter Property="Background" Value="{StaticResource UnoDock_VS2013_ContentBackground}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:LayoutDocumentPaneControl">
                    <Grid Background="{TemplateBinding Background}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Tab strip: no bottom border here — BD border provides it.
                             Column 0 (*): scrolling tab strip.
                             Column 1 (Auto): overflow ⌄ button (hidden when no docs). -->
                        <Grid x:Name="PART_TabStripHost"
                              Grid.Row="0"
                              Background="{StaticResource UnoDock_VS2013_TabBarBackground}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- BD: 2px active-tab-color line at bottom of tab strip.
                                 Spans both columns so the accent line covers the full width. -->
                            <Border x:Name="BD"
                                    Grid.Column="0" Grid.ColumnSpan="2"
                                    BorderBrush="{StaticResource UnoDock_VS2013_DocumentWellTabSelectedActiveBackground}"
                                    BorderThickness="0,0,0,2" />

                            <!-- Tab items (clipped at column right edge when tabs overflow) -->
                            <ItemsControl x:Name="PART_TabStrip"
                                          Grid.Column="0"
                                          ItemsSource="{TemplateBinding ItemsSource}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!-- Pure color rectangle. Margin bottom=2 leaves a 2px gap at the
                                             bottom of the tab strip; BD renders its 2px accent line in that
                                             gap, producing a continuous blue line under ALL tabs. -->
                                        <Border x:Name="TabOuter"
                                                Background="Transparent"
                                                Margin="0,0,0,2"
                                                Tag="{Binding}"
                                                AutomationProperties.AutomationId="{Binding ContentId}">
                                            <StackPanel Orientation="Horizontal"
                                                        Padding="10,1,4,1"
                                                        MinWidth="80"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource UnoDock_VS2013_TabText}"
                                                           FontSize="12" />
                                                <!-- Opacity=0+IsHitTestVisible=False acts as WPF Visibility.Hidden:
                                                     reserves layout space so tab width is stable on hover.
                                                     Collapsed is only used when CanClose=false (no space at all). -->
                                                <Button x:Name="CloseBtn"
                                                        Width="16" Height="16"
                                                        Margin="6,0,0,0"
                                                        Padding="0"
                                                        CornerRadius="2"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Opacity="0"
                                                        IsHitTestVisible="False"
                                                        VerticalAlignment="Center"
                                                        Tag="{Binding}"
                                                        ToolTipService.ToolTip="Close">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    CornerRadius="{TemplateBinding CornerRadius}">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center" />
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                    <TextBlock Text="✕"
                                                               FontSize="9"
                                                               Foreground="{StaticResource UnoDock_VS2013_CloseButtonForeground}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Overflow button — shows all docs in a MenuFlyout.
                                 Background/glyph colours set imperatively from code-behind
                                 using the DocumentWellOverflowButton* resource keys.
                                 Custom template suppresses WinUI's default hover chrome. -->
                            <Button x:Name="PART_OverflowButton"
                                    Grid.Column="1"
                                    Width="22"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    VerticalAlignment="Stretch"
                                    ToolTipService.ToolTip="Document list"
                                    Visibility="Collapsed">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <Path x:Name="PART_OverflowGlyph"
                                      Data="{StaticResource UnoDock_VS2013_PinDocMenuGeometryData}"
                                      Fill="{StaticResource UnoDock_VS2013_DocumentWellOverflowButtonDefaultGlyph}"
                                      Stretch="Uniform"
                                      Height="8"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                            </Button>
                        </Grid>

                        <!-- Content area: 1px PanelBorderBrush on L/R/B; top=0 (BD covers it) -->
                        <Border Grid.Row="1"
                                Background="{StaticResource UnoDock_VS2013_ContentBackground}"
                                BorderBrush="{StaticResource UnoDock_VS2013_PanelBorderBrush}"
                                BorderThickness="1,0,1,1">
                            <ContentPresenter Content="{TemplateBinding SelectedContent}" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── LayoutAnchorablePaneControl ──────────────────────────────────── -->
    <Style TargetType="controls:LayoutAnchorablePaneControl">
        <Setter Property="Background" Value="{StaticResource UnoDock_VS2013_ContentBackground}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:LayoutAnchorablePaneControl">
                    <Grid Background="{TemplateBinding Background}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Grid.RowSpan="2"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource UnoDock_VS2013_PanelBorderBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                        <!-- Tool pane caption/header (VS-like) -->
                        <Border x:Name="PART_HeaderBorder"
                                Grid.Row="0"
                                Background="{StaticResource UnoDock_VS2013_TabBarBackground}"
                                BorderThickness="0"
                                Padding="2,2,3,3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock x:Name="PART_HeaderTitle"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource UnoDock_VS2013_TabText}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Text="{Binding SelectedItem.Title, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=Tool Window}" />

                                <!-- Grip dots: diagonal 1×1 px rects tiled at 4px pitch, matching
                                     WPF VS2013 DragHandleTexture (DrawingBrush Viewbox=0,0,4,4).
                                     The Data below is an initial placeholder; LayoutAnchorablePaneControl
                                     regenerates it to span the actual header width (WinUI has no
                                     tiling brush, so the dots are retiled in code-behind). -->
                                <Path x:Name="PART_HeaderGrip"
                                      Grid.Column="1"
                                      Height="5"
                                      Margin="4,0,2,0"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Center"
                                      Fill="{StaticResource UnoDock_VS2013_ToolWindowCaptionInactiveGrip}"
                                      Data="M0,0 h1 v1 h-1z M4,0 h1 v1 h-1z M8,0 h1 v1 h-1z M12,0 h1 v1 h-1z M16,0 h1 v1 h-1z M20,0 h1 v1 h-1z M24,0 h1 v1 h-1z M28,0 h1 v1 h-1z M32,0 h1 v1 h-1z M36,0 h1 v1 h-1z M40,0 h1 v1 h-1z M44,0 h1 v1 h-1z M48,0 h1 v1 h-1z M52,0 h1 v1 h-1z M56,0 h1 v1 h-1z M60,0 h1 v1 h-1z M64,0 h1 v1 h-1z M68,0 h1 v1 h-1z M72,0 h1 v1 h-1z M76,0 h1 v1 h-1z M80,0 h1 v1 h-1z M84,0 h1 v1 h-1z M88,0 h1 v1 h-1z M92,0 h1 v1 h-1z M96,0 h1 v1 h-1z M100,0 h1 v1 h-1z M104,0 h1 v1 h-1z M108,0 h1 v1 h-1z M112,0 h1 v1 h-1z M116,0 h1 v1 h-1z M120,0 h1 v1 h-1z M124,0 h1 v1 h-1z M128,0 h1 v1 h-1z M132,0 h1 v1 h-1z M136,0 h1 v1 h-1z M140,0 h1 v1 h-1z M144,0 h1 v1 h-1z M148,0 h1 v1 h-1z M152,0 h1 v1 h-1z M156,0 h1 v1 h-1z M160,0 h1 v1 h-1z M164,0 h1 v1 h-1z M168,0 h1 v1 h-1z M172,0 h1 v1 h-1z M176,0 h1 v1 h-1z M180,0 h1 v1 h-1z M184,0 h1 v1 h-1z M188,0 h1 v1 h-1z M192,0 h1 v1 h-1z M196,0 h1 v1 h-1z M2,2 h1 v1 h-1z M6,2 h1 v1 h-1z M10,2 h1 v1 h-1z M14,2 h1 v1 h-1z M18,2 h1 v1 h-1z M22,2 h1 v1 h-1z M26,2 h1 v1 h-1z M30,2 h1 v1 h-1z M34,2 h1 v1 h-1z M38,2 h1 v1 h-1z M42,2 h1 v1 h-1z M46,2 h1 v1 h-1z M50,2 h1 v1 h-1z M54,2 h1 v1 h-1z M58,2 h1 v1 h-1z M62,2 h1 v1 h-1z M66,2 h1 v1 h-1z M70,2 h1 v1 h-1z M74,2 h1 v1 h-1z M78,2 h1 v1 h-1z M82,2 h1 v1 h-1z M86,2 h1 v1 h-1z M90,2 h1 v1 h-1z M94,2 h1 v1 h-1z M98,2 h1 v1 h-1z M102,2 h1 v1 h-1z M106,2 h1 v1 h-1z M110,2 h1 v1 h-1z M114,2 h1 v1 h-1z M118,2 h1 v1 h-1z M122,2 h1 v1 h-1z M126,2 h1 v1 h-1z M130,2 h1 v1 h-1z M134,2 h1 v1 h-1z M138,2 h1 v1 h-1z M142,2 h1 v1 h-1z M146,2 h1 v1 h-1z M150,2 h1 v1 h-1z M154,2 h1 v1 h-1z M158,2 h1 v1 h-1z M162,2 h1 v1 h-1z M166,2 h1 v1 h-1z M170,2 h1 v1 h-1z M174,2 h1 v1 h-1z M178,2 h1 v1 h-1z M182,2 h1 v1 h-1z M186,2 h1 v1 h-1z M190,2 h1 v1 h-1z M194,2 h1 v1 h-1z M198,2 h1 v1 h-1z" />

                                <Button x:Name="PART_HeaderMenu"
                                        Grid.Column="2"
                                        Width="15" Height="15"
                                        Margin="1,1,1,0"
                                        Padding="0"
                                        Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="1"
                                        VerticalAlignment="Center"
                                        ToolTipService.ToolTip="Window menu">
                                    <Path Width="8"
                                          Height="8"
                                          Margin="0,0,0,1"
                                          Data="M 352.041,32.0005L 320,0.000162761L 384,0.000162761L 352.041,32.0005 Z"
                                          Fill="{StaticResource UnoDock_VS2013_ToolWindowCaptionButtonInactiveGlyph}"
                                          Stretch="Uniform" />
                                </Button>

                                <Button x:Name="PART_HeaderAutoHide"
                                        Grid.Column="3"
                                        Width="15" Height="15"
                                        Margin="1,1,1,0"
                                        Padding="0"
                                        Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="1"
                                        VerticalAlignment="Center"
                                        ToolTipService.ToolTip="Auto Hide">
                                    <Path Width="11"
                                          Height="11"
                                          Data="M 128,17.475L 130.842,17.475L 130.842,2.91001L 130.842,0.608195L 130.842,0.000223796L 139.593,0.000223796L 145.003,0.000223796L 145.424,0.000223796L 145.424,17.475L 148.413,17.475L 148.413,20.3848L 139.684,20.3848L 139.684,32.0003L 136.752,32.0003L 136.752,20.3848L 128,20.3848L 128,17.475 Z M 133.774,2.91007L 133.774,17.475L 139.593,17.475L 139.593,2.91007L 133.774,2.91007 Z"
                                          Fill="{StaticResource UnoDock_VS2013_ToolWindowCaptionButtonInactiveGlyph}"
                                          Stretch="Uniform" />
                                </Button>

                                <Button x:Name="PART_HeaderClose"
                                        Grid.Column="4"
                                        Width="15" Height="15"
                                        Margin="0,1,1,0"
                                        Padding="0"
                                        Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="1"
                                        VerticalAlignment="Center"
                                        ToolTipService.ToolTip="Close">
                                    <Path Width="10"
                                          Height="10"
                                          Margin="1,0,0,1"
                                          Data="M 0,2.0345e-005L 7.62109,2.0345e-005L 19.2627,12.0551L 30.9043,2.0345e-005L 38.5241,2.0345e-005L 23.0726,16.0003L 38.5234,32L 30.9023,32L 19.2621,19.9462L 7.62177,32L 0.00195313,32L 15.4521,16.001L 0,2.0345e-005 Z"
                                          Fill="{StaticResource UnoDock_VS2013_ToolWindowCaptionButtonInactiveGlyph}"
                                          Stretch="Uniform" />
                                </Button>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Background="{StaticResource UnoDock_VS2013_ContentBackground}"
                                Padding="4">
                            <ContentPresenter Content="{TemplateBinding SelectedContent}" />
                        </Border>
                            </Grid>
                        </Border>

                        <!-- Tab strip. The selected tab supplies the slim WPF-style outline;
                             no extra strip border here, otherwise it doubles up with pane chrome. -->
                        <Border x:Name="PART_TabStripHost"
                                Grid.Row="2"
                                Background="{StaticResource UnoDock_VS2013_TabBarBackground}"
                                BorderBrush="{StaticResource UnoDock_VS2013_TabBarBorderBrush}"
                                BorderThickness="0">
                            <ItemsControl x:Name="PART_TabStrip"
                                          ItemsSource="{TemplateBinding ItemsSource}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <!-- SelectedBD: erases the strip's top separator at the active tab.
                                                 Margin top=-1 extends it 1px above the strip's top border.
                                                 BorderBrush set by code-behind to match selected tab background. -->
                                            <Border x:Name="SelectedBD"
                                                    Margin="1,-1,1,0"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="0,1,0,0"
                                                    Visibility="Collapsed" />
                                            <!-- Main tab body: transparent borders by default, PanelBorderBrush
                                                 on L/R/B when selected. No top border (SelectedBD handles it). -->
                                            <Border x:Name="TabOuter"
                                                    MinHeight="21"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="1,0,1,1"
                                                    Tag="{Binding}"
                                                    AutomationProperties.AutomationId="{Binding ContentId}">
                                                <TextBlock Text="{Binding Title}"
                                                           Padding="6,1,6,3"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource UnoDock_VS2013_ToolWindowTabUnselectedText}"
                                                           FontSize="11" />
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── LayoutGridResizerControl ─────────────────────────────────────── -->
    <Style TargetType="controls:LayoutGridResizerControl">
        <Setter Property="Background" Value="{StaticResource UnoDock_VS2013_ResizerBackground}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:LayoutGridResizerControl">
                    <Grid Background="{TemplateBinding Background}">
                        <Thumb x:Name="PART_Thumb"
                               Background="Transparent"
                               Opacity="0" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
